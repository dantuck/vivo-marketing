---
interface ReleaseSection {
  title: string;
  entries: string[];
}

interface Release {
  version: string;
  date: string;
  url: string;
  sections: ReleaseSection[];
}

let releases: Release[] = [];

try {
  const res = await fetch(
    'https://raw.githubusercontent.com/dantuck/vivo/main/CHANGELOG.md',
    { headers: { 'User-Agent': 'vivo-marketing-site (claudeai@danieltucker.dev)' } },
  );
  if (res.ok) {
    const text = await res.text();
    const blocks = text.split(/\n## \[/).slice(1);
    releases = blocks.slice(0, 5).map((block): Release => {
      const lines = block.split('\n');
      const m = lines[0].match(/^([^\]]+)\]\(([^)]+)\)\s+\(([^)]+)\)/);
      const version = m?.[1] ?? 'unknown';
      const url = m?.[2] ?? '';
      const date = m?.[3] ?? '';

      const sections: ReleaseSection[] = lines
        .slice(1)
        .join('\n')
        .split(/\n### /)
        .slice(1)
        .map(s => {
          const sLines = s.split('\n');
          return {
            title: sLines[0].trim(),
            entries: sLines
              .slice(1)
              .filter(l => l.startsWith('* '))
              .map(l =>
                l.slice(2).replace(/\s*\([a-f0-9]{7,}\]\([^)]+\)\)/g, '').trim(),
              ),
          };
        })
        .filter(s => s.entries.length > 0);

      return { version, date, url, sections };
    });
  }
} catch {
  // silently fail — renders nothing if fetch errors
}
---

{releases.length > 0 && (
  <section class="releases" id="releases">
    <div class="inner">
      <p class="label">Changelog</p>
      <h2>What's new.</h2>
      <div class="list">
        {releases.map(r => (
          <div class="release">
            <div class="release-header">
              <a href={r.url} target="_blank" rel="noopener" class="version">v{r.version}</a>
              <span class="date">{r.date}</span>
            </div>
            {r.sections.map(s => (
              <div class="section">
                <p class="section-title">{s.title}</p>
                <ul>
                  {s.entries.map(e => <li>{e}</li>)}
                </ul>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .releases {
    background: var(--bg2);
    padding: 80px 48px;
    transition: background 0.2s;
  }

  .inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  h2 {
    font-size: clamp(28px, 4vw, 38px);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-bottom: 36px;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .release {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px 24px;
  }

  .release-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }

  .version {
    font-size: 15px;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
  }

  .version:hover { text-decoration: underline; }

  .date {
    font-size: 13px;
    color: var(--muted);
  }

  .section { margin-bottom: 10px; }

  .section-title {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 6px;
  }

  ul { list-style: none; padding: 0; margin: 0; }

  li {
    font-size: 14px;
    color: var(--text);
    padding: 2px 0 2px 16px;
    position: relative;
    line-height: 1.6;
  }

  li::before {
    content: '·';
    position: absolute;
    left: 4px;
    color: var(--muted);
  }

  @media (max-width: 768px) {
    .releases { padding: 64px 20px; }
  }
</style>
